generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  SHOP_OWNER
  BARBER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TimeSlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                    String    @id @default(uuid()) @db.Uuid
  email                 String    @unique
  phone                 String?
  passwordHash          String
  role                  UserRole
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerProfile CustomerProfile?
  ownerProfile    ShopOwnerProfile?
  adminProfile    AdminProfile?
  barberProfile   Barber?
}

model CustomerProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  firstName String
  lastName  String

  avatar String?

  walletBalance Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]
  reviews      Review[]

  favoriteBarbers FavoriteBarber[]
  favoriteShops   FavoriteShop[]
}

model ShopOwnerProfile {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @db.Uuid
  firstName         String
  lastName          String
  avatarUrl         String?
  businessLegalName String?
  gstin             String?   @unique
  panNumber         String?   @unique
  kycStatus         KycStatus @default(NOT_SUBMITTED)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shops          Shop[]
  payoutAccounts PayoutAccount[]
}

model AdminProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  firstName   String
  lastName    String
  avatarUrl   String?
  designation String?
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shop {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @db.Uuid
  name         String
  description  String?
  phone        String?
  email        String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String?
  postalCode   String
  country      String
  latitude     Decimal? @db.Decimal(9, 6)
  longitude    Decimal? @db.Decimal(9, 6)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner        ShopOwnerProfile @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  barbers      Barber[]
  services     Service[]
  appointments Appointment[]
  reviews      Review[]
  favoritedBy  FavoriteShop[]

  @@index([ownerId])
  @@index([city])
}

model Barber {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @unique @db.Uuid
  shopId      String   @db.Uuid
  displayName String
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  timeSlots       TimeSlot[]
  appointments    Appointment[]
  reviews         Review[]
  portfolioImages PortfolioImage[]
  favoritedBy     FavoriteBarber[]

  @@index([shopId])
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  shopId      String   @db.Uuid
  name        String
  description String?
  durationMin Int
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([shopId])
}

model TimeSlot {
  id        String         @id @default(uuid()) @db.Uuid
  barberId  String         @db.Uuid
  startsAt  DateTime
  endsAt    DateTime
  status    TimeSlotStatus @default(AVAILABLE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  barber      Barber       @relation(fields: [barberId], references: [id], onDelete: Cascade)
  appointment Appointment?

  @@unique([barberId, startsAt])
  @@index([barberId, startsAt])
}

model Appointment {
  id         String            @id @default(uuid()) @db.Uuid
  customerId String            @db.Uuid
  shopId     String            @db.Uuid
  barberId   String            @db.Uuid
  serviceId  String            @db.Uuid
  timeSlotId String            @unique @db.Uuid
  status     AppointmentStatus @default(PENDING)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Restrict)
  shop     Shop            @relation(fields: [shopId], references: [id], onDelete: Restrict)
  barber   Barber          @relation(fields: [barberId], references: [id], onDelete: Restrict)
  service  Service         @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  timeSlot TimeSlot        @relation(fields: [timeSlotId], references: [id], onDelete: Restrict)
  review   Review?

  @@index([customerId, createdAt])
  @@index([shopId, status])
  @@index([barberId, status])
}

model Review {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @db.Uuid
  shopId        String   @db.Uuid
  barberId      String?  @db.Uuid
  appointmentId String   @unique @db.Uuid
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Restrict)
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber      Barber?         @relation(fields: [barberId], references: [id], onDelete: SetNull)
  appointment Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([barberId, createdAt])
}

model PortfolioImage {
  id        String   @id @default(uuid()) @db.Uuid
  barberId  String   @db.Uuid
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, sortOrder])
}

model FavoriteBarber {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  barberId   String   @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  barber   Barber          @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([customerId, barberId])
  @@index([barberId])
}

model FavoriteShop {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  shopId     String   @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop     Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([customerId, shopId])
  @@index([shopId])
}

model PayoutAccount {
  id                String   @id @default(uuid()) @db.Uuid
  ownerId           String   @db.Uuid
  accountHolderName String
  bankName          String
  accountNumber     String
  ifscCode          String
  isPrimary         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  owner ShopOwnerProfile @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

{
  "name": "trimly",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": { "node": ">=20.11.0", "pnpm": ">=9.0.0" },
  "scripts": {
    "dev": "pnpm --parallel --filter ./frontend --filter ./backend dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:backend": "pnpm --dir backend start:dev",
    "build": "pnpm --filter ./frontend build && pnpm --filter ./backend build"
  }
}
